# =============================================================================
# BASE DE DATOS POSTGRESQL (servidor remoto)
# =============================================================================
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/clinicos_dev?schema=public"

# =============================================================================
# REDIS (Docker local)
# =============================================================================
REDIS_URL="redis://localhost:6379"

# =============================================================================
# MINIO - Almacenamiento de archivos (Docker local)
# =============================================================================
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="clinicos_minio"
MINIO_SECRET_KEY="clinicos_minio_secret"
MINIO_BUCKET_IMAGES="procedure-images"
MINIO_BUCKET_DOCUMENTS="documents"
MINIO_BUCKET_BACKUPS="backups"

# =============================================================================
# MEILISEARCH - Motor de búsqueda (Docker local)
# =============================================================================
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="clinicos_meili_key"

# =============================================================================
# JWT AUTH
# =============================================================================
JWT_ACCESS_SECRET="CHANGE_ME_ACCESS_SECRET_MIN_32_CHARS"
JWT_REFRESH_SECRET="CHANGE_ME_REFRESH_SECRET_MIN_32_CHARS"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# =============================================================================
# API (NestJS)
# =============================================================================
API_PORT="3001"
API_URL="http://localhost:3001"
NODE_ENV="development"

# =============================================================================
# WEB (Next.js)
# =============================================================================
NEXT_PUBLIC_API_URL="http://localhost:3001"
WEB_PORT="3000"

# =============================================================================
# EMAIL (MailHog en dev, SMTP real en prod)
# =============================================================================
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@clinicos.app"

# =============================================================================
# NOTIFICACIONES WHATSAPP (Twilio - solo prod)
# =============================================================================
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
