  cancelledBy               String?   @map("cancelled_by") @db.VarChar(20)
  cancelledAt               DateTime? @map("cancelled_at") @db.Timestamptz(6)
  isLateCancellation        Boolean?  @default(false) @map("is_late_cancellation")
  procedureReportId         String?   @map("procedure_report_id") @db.Uuid
  source                    String    @default("reception") @db.VarChar(30)
  notes                     String?
  createdBy                 String    @map("created_by") @db.Uuid
