  phoneSecondary       String?   @map("phone_secondary") @db.VarChar(20)
  email                String?   @db.VarChar(200)
  address              String?   @db.VarChar(300)
  municipalityCode     String?   @map("municipality_code") @db.VarChar(10)
  zone                 String?   @db.VarChar(10)
  maritalStatus        String?   @map("marital_status") @db.VarChar(20)
  educationLevel       String?   @map("education_level") @db.VarChar(50)
  occupation           String?   @db.VarChar(100)
  ethnicity            String    @default("none") @db.VarChar(50)
  disability           String    @default("none") @db.VarChar(50)
  payerType            String?   @map("payer_type") @db.VarChar(30)
  payerId              String?   @map("payer_id") @db.Uuid
  payerName            String?   @map("payer_name") @db.VarChar(200)
  affiliateType        String?   @map("affiliate_type") @db.VarChar(20)
  emergencyContact     Json?     @map("emergency_contact")
  defaultCompanion     Json?     @map("default_companion")
  noShowCount          Int       @default(0) @map("no_show_count")
  selfScheduleBlocked  Boolean   @default(false) @map("self_schedule_blocked")
  mergedIntoId         String?   @map("merged_into_id") @db.Uuid
  mergedAt             DateTime? @map("merged_at") @db.Timestamptz(6)
