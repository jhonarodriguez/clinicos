  dataConsentSignedAt  DateTime? @map("data_consent_signed_at") @db.Timestamptz(6)
  isActive             Boolean   @default(true) @map("is_active")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  mergedInto       Patient?          @relation("PatientMerge", fields: [mergedIntoId], references: [id])
  mergedFrom       Patient[]         @relation("PatientMerge")
  consents         PatientConsent[]
  appointments     Appointment[]
  procedures       Procedure[]
  waitlistEntries  WaitlistEntry[]
  medicalRecords   MedicalRecord[]
  procedureReports ProcedureReport[]
  diagnoses        Diagnosis[]       @relation("DiagnosisPatient")
  medicalOrders    MedicalOrder[]
  prescriptions    Prescription[]
  procedureImages  ProcedureImage[]
  biopsySamples    BiopsySample[]
  invoices         Invoice[]
  payments         Payment[]
  copayAccumulators PatientCopayAccumulator[]
  treatmentPrograms TreatmentProgram[]
  notifications    Notification[]
  adverseEvents    AdverseEvent[]

  @@unique([tenantId, documentType, documentNumber])
  @@index([tenantId], name: "idx_patients_tenant")
  @@index([tenantId, documentNumber], name: "idx_patients_tenant_doc")
  @@index([tenantId, firstLastName, firstName], name: "idx_patients_tenant_name")
  @@index([tenantId, phone], name: "idx_patients_tenant_phone")
  @@map("patients")
}

