  claims      Claim[]
  payments    Payment[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, createdAt(sort: Desc)], name: "idx_invoices_tenant")
  @@index([tenantId, patientId], name: "idx_invoices_tenant_patient")
  @@index([tenantId, payerId, status], name: "idx_invoices_tenant_payer")
  @@index([tenantId, status, createdAt], name: "idx_invoices_status")
  @@map("invoices")
}

