// audit_logs es particionada por mes en PostgreSQL.
// Prisma la gestiona como tabla regular; el particionamiento
// se aplica vía migración SQL personalizada.
model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(30)
  entityType String   @map("entity_type") @db.VarChar(100)
  entityId   String?  @map("entity_id") @db.Uuid
  changes    Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent")
  sessionId  String?  @map("session_id") @db.Uuid
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tenantId, createdAt(sort: Desc)], name: "idx_audit_tenant_time")
  @@index([tenantId, entityType, entityId], name: "idx_audit_entity")
  @@index([tenantId, userId, createdAt(sort: Desc)], name: "idx_audit_user")
  @@map("audit_logs")
}

