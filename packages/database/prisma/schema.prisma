// =============================================================================
// ClinicOS — Prisma Schema completo
// 51 tablas / 7 bounded contexts / PostgreSQL 16 con RLS
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// 1. IDENTITY CONTEXT
// =============================================================================

model Tenant {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String    @db.VarChar(200)
  tradeName          String?   @map("trade_name") @db.VarChar(200)
  nit                String    @unique @db.VarChar(20)
  verificationDigit  String?   @map("verification_digit") @db.Char(1)
  ipsCode            String?   @map("ips_code") @db.VarChar(20)
  complexityLevel    String?   @map("complexity_level") @db.VarChar(20)
  ipsType            String?   @map("ips_type") @db.VarChar(50)
  legalRepName       String?   @map("legal_rep_name") @db.VarChar(200)
  legalRepDocument   String?   @map("legal_rep_document") @db.VarChar(20)
  phone              String?   @db.VarChar(20)
  email              String?   @db.VarChar(200)
  logoUrl            String?   @map("logo_url") @db.VarChar(500)
  branding           Json      @default("{}")
  settings           Json      @default("{}")
  timezone           String    @default("America/Bogota") @db.VarChar(50)
  subscriptionPlan   String    @default("starter") @map("subscription_plan") @db.VarChar(50)
  subscriptionStatus String    @default("trial") @map("subscription_status") @db.VarChar(20)
  trialEndsAt        DateTime? @map("trial_ends_at") @db.Timestamptz(6)
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  sites            TenantSite[]
  features         TenantFeature[]
  users            User[]
  roles            Role[]
  professionals    Professional[]
  rooms            Room[]
  equipment        Equipment[]
  serviceTypes     ServiceType[]
  scheduleBlocks   ScheduleBlock[]
  appointments     Appointment[]
  procedures       Procedure[]
  waitlistEntries  WaitlistEntry[]
  patients         Patient[]
  medicalRecords   MedicalRecord[]
  procedureReports ProcedureReport[]
  diagnoses        Diagnosis[]
  medicalOrders    MedicalOrder[]
  prescriptions    Prescription[]
  procedureImages  ProcedureImage[]
  biopsySamples    BiopsySample[]
  payers           Payer[]
  contracts        Contract[]
  invoices         Invoice[]
  claims           Claim[]
  payments         Payment[]
  copaymentRules   CopaymentRule[]
  copayAccumulators PatientCopayAccumulator[]
  treatmentPrograms TreatmentProgram[]
  preparationProtocols PreparationProtocol[]
  notifications    Notification[]
  adverseEvents    AdverseEvent[]
  sessions         Session[]
  specialties      Specialty[]
  patientConsents       PatientConsent[]
  professionalSchedules ProfessionalSchedule[]

  @@map("tenants")
}

model TenantSite {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  name             String   @db.VarChar(200)
  address          String   @db.VarChar(300)
  city             String   @db.VarChar(100)
  department       String?  @db.VarChar(100)
  municipalityCode String?  @map("municipality_code") @db.VarChar(10)
  phone            String?  @db.VarChar(20)
  email            String?  @db.VarChar(200)
  schedule         Json     @default("{}")
  isMain           Boolean  @default(false) @map("is_main")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  rooms                Room[]
  equipment            Equipment[]
  professionalSchedules ProfessionalSchedule[]
  appointments         Appointment[]
  procedures           Procedure[]
  medicalRecords       MedicalRecord[]
  procedureReports     ProcedureReport[]
  userRoles            UserRole[]

  @@unique([tenantId, name])
  @@index([tenantId], name: "idx_tenant_sites_tenant")
  @@map("tenant_sites")
}

model TenantFeature {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  featureKey String    @map("feature_key") @db.VarChar(100)
  isEnabled  Boolean   @default(false) @map("is_enabled")
  config     Json      @default("{}")
  enabledAt  DateTime? @map("enabled_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, featureKey])
  @@index([tenantId], name: "idx_tenant_features_tenant")
  @@map("tenant_features")
}

model User {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  email             String    @db.VarChar(200)
  passwordHash      String    @map("password_hash") @db.VarChar(200)
  firstName         String    @map("first_name") @db.VarChar(100)
  lastName          String    @map("last_name") @db.VarChar(100)
  phone             String?   @db.VarChar(20)
  avatarUrl         String?   @map("avatar_url") @db.VarChar(500)
  isActive          Boolean   @default(true) @map("is_active")
  isSuperAdmin      Boolean   @default(false) @map("is_super_admin")
  hasMfa            Boolean   @default(false) @map("has_mfa")
  mfaSecret         String?   @map("mfa_secret") @db.VarChar(200)
  passwordChangedAt DateTime? @map("password_changed_at") @db.Timestamptz(6)
  failedLoginCount  Int       @default(0) @map("failed_login_count")
  lockedUntil       DateTime? @map("locked_until") @db.Timestamptz(6)
  lastLoginAt       DateTime? @map("last_login_at") @db.Timestamptz(6)
  lastLoginIp       String?   @map("last_login_ip") @db.VarChar(45)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  sessions           Session[]
  roles              UserRole[]
  professional       Professional?
  scheduleBlocksCreated ScheduleBlock[]  @relation("ScheduleBlockCreatedBy")
  appointmentsCreated   Appointment[]    @relation("AppointmentCreatedBy")
  proceduresCreated     Procedure[]      @relation("ProcedureCreatedBy")
  medicalRecordSections MedicalRecordSection[]
  treatmentProgramsCreated TreatmentProgram[] @relation("TreatmentProgramCreatedBy")
  invoicesIssued     Invoice[]           @relation("InvoiceIssuedBy")
  claimsResponded    Claim[]             @relation("ClaimRespondedBy")
  paymentsReceived   Payment[]           @relation("PaymentReceivedBy")
  procedureImagesUploaded ProcedureImage[] @relation("ProcedureImageUploadedBy")
  biopsySamplesSent  BiopsySample[]      @relation("BiopsySampleSentBy")
  adverseEventsReported AdverseEvent[]   @relation("AdverseEventReportedBy")
  userRolesAssigned  UserRole[]          @relation("UserRoleAssignedBy")

  @@unique([tenantId, email])
  @@index([tenantId], name: "idx_users_tenant")
  @@index([tenantId, email], name: "idx_users_tenant_email")
  @@map("users")
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(100)
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  users       UserRole[]

  @@unique([tenantId, name])
  @@index([tenantId], name: "idx_roles_tenant")
  @@map("roles")
}

model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  module      String   @db.VarChar(50)
  resource    String   @db.VarChar(50)
  action      String   @db.VarChar(50)
  description String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  roles RolePermission[]

  @@unique([module, resource, action])
  @@map("permissions")
}

model RolePermission {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid
  scope        String @default("all") @db.VarChar(50)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId], name: "idx_role_permissions_role")
  @@map("role_permissions")
}

model UserRole {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  roleId     String    @map("role_id") @db.Uuid
  siteId     String?   @map("site_id") @db.Uuid
  assignedAt DateTime  @default(now()) @map("assigned_at") @db.Timestamptz(6)
  assignedBy String?   @map("assigned_by") @db.Uuid

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  site       TenantSite? @relation(fields: [siteId], references: [id])
  assignedByUser User?  @relation("UserRoleAssignedBy", fields: [assignedBy], references: [id])

  @@unique([userId, roleId, siteId])
  @@index([userId], name: "idx_user_roles_user")
  @@map("user_roles")
}

model Session {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  refreshToken String    @unique @map("refresh_token")
  ipAddress    String    @map("ip_address") @db.VarChar(45)
  userAgent    String?   @map("user_agent")
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([userId], name: "idx_sessions_user")
  @@index([refreshToken], name: "idx_sessions_token")
  @@index([expiresAt], name: "idx_sessions_expires")
  @@map("sessions")
}

// =============================================================================
// 2. SCHEDULING CONTEXT
// =============================================================================

model Specialty {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String? @map("tenant_id") @db.Uuid
  name     String  @db.VarChar(200)
  code     String? @db.VarChar(20)
  parentId String? @map("parent_id") @db.Uuid
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant        Tenant?               @relation(fields: [tenantId], references: [id])
  parent        Specialty?            @relation("SpecialtyParent", fields: [parentId], references: [id])
  children      Specialty[]           @relation("SpecialtyParent")
  professionals ProfessionalSpecialty[]
  appointments  Appointment[]

  @@index([tenantId], name: "idx_specialties_tenant")
  @@index([parentId], name: "idx_specialties_parent")
  @@map("specialties")
}

model Professional {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String   @map("tenant_id") @db.Uuid
  userId               String   @unique @map("user_id") @db.Uuid
  professionalCard     String?  @map("professional_card") @db.VarChar(50)
  registrationNumber   String?  @map("registration_number") @db.VarChar(50)
  documentType         String   @map("document_type") @db.VarChar(10)
  documentNumber       String   @map("document_number") @db.VarChar(20)
  digitalSignatureUrl  String?  @map("digital_signature_url") @db.VarChar(500)
  stampUrl             String?  @map("stamp_url") @db.VarChar(500)
  qrVerificationData   Json?    @map("qr_verification_data")
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant                    Tenant                  @relation(fields: [tenantId], references: [id])
  user                      User                    @relation(fields: [userId], references: [id])
  specialties               ProfessionalSpecialty[]
  schedules                 ProfessionalSchedule[]
  appointmentsAsPrimary     Appointment[]           @relation("AppointmentProfessional")
  proceduresAsPrimary       Procedure[]             @relation("ProcedurePrimary")
  proceduresAsAnesthesiologist Procedure[]          @relation("ProcedureAnesthesiologist")
  medicalRecords            MedicalRecord[]
  procedureReportsAsPrimary ProcedureReport[]       @relation("ReportPrimary")
  procedureReportsAsAnesthesiologist ProcedureReport[] @relation("ReportAnesthesiologist")
  diagnoses                 Diagnosis[]             @relation("DiagnosisProfessional")
  medicalOrders             MedicalOrder[]
  prescriptions             Prescription[]
  biopsySamples             BiopsySample[]          @relation("BiopsySampleProfessional")
  biopsySamplesReviewed     BiopsySample[]          @relation("BiopsySampleReviewedBy")
  invoiceItems              InvoiceItem[]
  treatmentPrograms         TreatmentProgram[]
  patientConsents           PatientConsent[]
  scheduleBlocks            ScheduleBlock[]
  waitlistEntries           WaitlistEntry[]

  @@unique([tenantId, userId])
  @@unique([tenantId, documentNumber])
  @@index([tenantId], name: "idx_professionals_tenant")
  @@index([userId], name: "idx_professionals_user")
  @@map("professionals")
}

model ProfessionalSpecialty {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  professionalId String  @map("professional_id") @db.Uuid
  specialtyId    String  @map("specialty_id") @db.Uuid
  isPrimary      Boolean @default(false) @map("is_primary")

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  specialty    Specialty    @relation(fields: [specialtyId], references: [id])

  @@unique([professionalId, specialtyId])
  @@index([professionalId], name: "idx_prof_spec_professional")
  @@map("professional_specialties")
}

model Room {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String  @map("tenant_id") @db.Uuid
  siteId   String  @map("site_id") @db.Uuid
  name     String  @db.VarChar(100)
  code     String? @db.VarChar(20)
  roomType String  @map("room_type") @db.VarChar(50)
  capacity Int?    @default(1)
  floor    String? @db.VarChar(20)
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  site          TenantSite      @relation(fields: [siteId], references: [id])
  equipment     Equipment[]
  scheduleBlocks ScheduleBlock[]
  appointments  Appointment[]
  procedures    Procedure[]

  @@unique([tenantId, siteId, code])
  @@index([tenantId, siteId], name: "idx_rooms_tenant_site")
  @@map("rooms")
}

model Equipment {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  siteId            String    @map("site_id") @db.Uuid
  name              String    @db.VarChar(200)
  code              String?   @db.VarChar(50)
  equipmentType     String    @map("equipment_type") @db.VarChar(100)
  brand             String?   @db.VarChar(100)
  model             String?   @db.VarChar(100)
  serialNumber      String?   @map("serial_number") @db.VarChar(100)
  roomId            String?   @map("room_id") @db.Uuid
  maintenanceStatus String    @default("operational") @map("maintenance_status") @db.VarChar(20)
  lastMaintenanceAt DateTime? @map("last_maintenance_at") @db.Timestamptz(6)
  nextMaintenanceAt DateTime? @map("next_maintenance_at") @db.Timestamptz(6)
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  site           TenantSite      @relation(fields: [siteId], references: [id])
  room           Room?           @relation(fields: [roomId], references: [id])
  scheduleBlocks ScheduleBlock[]
  procedures     Procedure[]

  @@index([tenantId], name: "idx_equipment_tenant")
  @@index([roomId], name: "idx_equipment_room")
  @@map("equipment")
}

model ServiceType {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String   @map("tenant_id") @db.Uuid
  name                  String   @db.VarChar(200)
  code                  String?  @db.VarChar(50)
  cupsCode              String?  @map("cups_code") @db.VarChar(20)
  category              String   @db.VarChar(50)
  defaultDurationMin    Int      @map("default_duration_min")
  recoveryDurationMin   Int      @default(0) @map("recovery_duration_min")
  cleanupDurationMin    Int      @default(0) @map("cleanup_duration_min")
  requiresSedation      Boolean  @default(false) @map("requires_sedation")
  requiresCompanion     Boolean  @default(false) @map("requires_companion")
  requiresAuthorization Boolean  @default(false) @map("requires_authorization")
  requiresConsent       Boolean  @default(false) @map("requires_consent")
  consentTemplateId     String?  @map("consent_template_id") @db.Uuid
  preparationProtocolId String?  @map("preparation_protocol_id") @db.Uuid
  canSelfSchedule       Boolean  @default(false) @map("can_self_schedule")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant               Tenant                     @relation(fields: [tenantId], references: [id])
  resourceRequirements ServiceResourceRequirement[]
  appointments         Appointment[]
  procedures           Procedure[]
  waitlistEntries      WaitlistEntry[]
  preparationProtocols PreparationProtocol[]

  @@unique([tenantId, code])
  @@index([tenantId], name: "idx_service_types_tenant")
  @@map("service_types")
}

model ServiceResourceRequirement {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceTypeId String  @map("service_type_id") @db.Uuid
  resourceType  String  @map("resource_type") @db.VarChar(50)
  resourceValue String  @map("resource_value") @db.VarChar(100)
  quantity      Int     @default(1)
  isRequired    Boolean @default(true) @map("is_required")

  serviceType ServiceType @relation(fields: [serviceTypeId], references: [id], onDelete: Cascade)

  @@unique([serviceTypeId, resourceType, resourceValue])
  @@map("service_resource_requirements")
}

model ProfessionalSchedule {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  professionalId      String    @map("professional_id") @db.Uuid
  siteId              String    @map("site_id") @db.Uuid
  dayOfWeek           Int       @map("day_of_week")
  startTime           DateTime  @map("start_time") @db.Time()
  endTime             DateTime  @map("end_time") @db.Time()
  slotDurationMin     Int       @default(20) @map("slot_duration_min")
  maxOverbooking      Int       @default(0) @map("max_overbooking")
  allowedServiceTypes String[]  @map("allowed_service_types") @db.Uuid
  validFrom           DateTime  @map("valid_from") @db.Date
  validUntil          DateTime? @map("valid_until") @db.Date
  isActive            Boolean   @default(true) @map("is_active")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  professional Professional @relation(fields: [professionalId], references: [id])
  site         TenantSite  @relation(fields: [siteId], references: [id])

  @@index([tenantId, professionalId], name: "idx_prof_schedules_tenant_prof")
  @@index([tenantId, professionalId, dayOfWeek], name: "idx_prof_schedules_day")
  @@map("professional_schedules")
}

model ScheduleBlock {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  blockType      String    @map("block_type") @db.VarChar(50)
  professionalId String?   @map("professional_id") @db.Uuid
  roomId         String?   @map("room_id") @db.Uuid
  equipmentId    String?   @map("equipment_id") @db.Uuid
  startDatetime  DateTime  @map("start_datetime") @db.Timestamptz(6)
  endDatetime    DateTime  @map("end_datetime") @db.Timestamptz(6)
  allDay         Boolean   @default(false) @map("all_day")
  reason         String?
  createdBy      String    @map("created_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  professional Professional? @relation(fields: [professionalId], references: [id])
  room         Room?         @relation(fields: [roomId], references: [id])
  equipment    Equipment?    @relation(fields: [equipmentId], references: [id])
  createdByUser User         @relation("ScheduleBlockCreatedBy", fields: [createdBy], references: [id])

  @@index([tenantId], name: "idx_schedule_blocks_tenant")
  @@index([tenantId, professionalId, startDatetime, endDatetime], name: "idx_schedule_blocks_prof")
  @@index([tenantId, roomId, startDatetime, endDatetime], name: "idx_schedule_blocks_room")
  @@map("schedule_blocks")
}

model Appointment {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  patientId           String    @map("patient_id") @db.Uuid
  professionalId      String    @map("professional_id") @db.Uuid
  siteId              String    @map("site_id") @db.Uuid
  roomId              String?   @map("room_id") @db.Uuid
  serviceTypeId       String    @map("service_type_id") @db.Uuid
  specialtyId         String?   @map("specialty_id") @db.Uuid
  scheduledStart      DateTime  @map("scheduled_start") @db.Timestamptz(6)
  scheduledEnd        DateTime  @map("scheduled_end") @db.Timestamptz(6)
  actualStart         DateTime? @map("actual_start") @db.Timestamptz(6)
  actualEnd           DateTime? @map("actual_end") @db.Timestamptz(6)
  status              String    @default("scheduled") @db.VarChar(30)
  isFirstVisit        Boolean   @default(false) @map("is_first_visit")
  isOverbooking       Boolean   @default(false) @map("is_overbooking")
  authorizationNumber String?   @map("authorization_number") @db.VarChar(50)
  cancellationReason  String?   @map("cancellation_reason")
  cancelledBy         String?   @map("cancelled_by") @db.VarChar(20)
  cancelledAt         DateTime? @map("cancelled_at") @db.Timestamptz(6)
  arrivalAt           DateTime? @map("arrival_at") @db.Timestamptz(6)
  source              String    @default("reception") @db.VarChar(30)
  notes               String?
  createdBy           String    @map("created_by") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  patient       Patient       @relation(fields: [patientId], references: [id])
