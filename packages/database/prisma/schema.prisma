  @@index([tenantId, scheduledStart], name: "idx_procedures_tenant_date")
  @@index([tenantId, primaryProfessionalId, scheduledStart], name: "idx_procedures_tenant_prof")
  @@index([tenantId, anesthesiologistId, scheduledStart], name: "idx_procedures_tenant_anest")
  @@index([tenantId, roomId, scheduledStart], name: "idx_procedures_tenant_room")
  @@index([tenantId, patientId], name: "idx_procedures_tenant_patient")
  @@index([tenantId, status, scheduledStart], name: "idx_procedures_status")
