  filedAt        DateTime? @map("filed_at") @db.Timestamptz(6)
  filedNumber    String?   @map("filed_number") @db.VarChar(50)
  paidAt         DateTime? @map("paid_at") @db.Timestamptz(6)
  paidAmount     Decimal?  @map("paid_amount") @db.Decimal(15, 2)
  voidedAt       DateTime? @map("voided_at") @db.Timestamptz(6)
  voidReason     String?   @map("void_reason")
  creditNoteId   String?   @map("credit_note_id") @db.Uuid
  issuedAt       DateTime? @map("issued_at") @db.Timestamptz(6)
  issuedBy       String?   @map("issued_by") @db.Uuid
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  patient     Patient       @relation(fields: [patientId], references: [id])
  payer       Payer?        @relation(fields: [payerId], references: [id])
  contract    Contract?     @relation(fields: [contractId], references: [id])
  appointment Appointment?  @relation(fields: [appointmentId], references: [id])
  procedure   Procedure?    @relation(fields: [procedureId], references: [id])
