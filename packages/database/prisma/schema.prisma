  immediateActions    String?   @map("immediate_actions")
  rootCauseAnalysis   String?   @map("root_cause_analysis")
  correctiveActions   String?   @map("corrective_actions")
  relatedProcedureId  String?   @map("related_procedure_id") @db.Uuid
  status              String    @default("reported") @db.VarChar(20)
  resolvedAt          DateTime? @map("resolved_at") @db.Timestamptz(6)
